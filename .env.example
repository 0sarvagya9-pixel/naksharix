# ------------------------------------------------------------
# Naksharix Environment Variables
# Copy this file to .env.local for local Next.js development,
# or set these variables in Vercel / Docker / your host.
# ------------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL="https://naksharix.com"
NEXT_PUBLIC_APP_NAME="Naksharix"
NEXT_PUBLIC_WHATSAPP_NUMBER="919999999999"
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naksharix?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/naksharix?schema=public"

# Auth / Sessions
# Use one strong 32+ character random value. Keep JWT_SECRET and NEXTAUTH_SECRET
# the same unless you later add a separate NextAuth.js provider layer.
NEXTAUTH_SECRET="replace-with-a-random-32-plus-character-secret"
NEXTAUTH_URL="https://naksharix.com"
JWT_SECRET="replace-with-a-random-32-plus-character-secret"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Google Gemini AI
# Server-side only. Create a key in Google AI Studio and add it to Vercel
# Project Settings > Environment Variables as GEMINI_API_KEY.
GEMINI_API_KEY=""

# Payments - Razorpay
RAZORPAY_KEY_ID=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
# Alias supported by the Razorpay Node SDK wrapper in this codebase.
RAZORPAY_KEY_SECRET=""

# Payments - Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PREMIUM_PRICE_ID=""
STRIPE_VIP_PRICE_ID=""
STRIPE_KUNDLI_REPORT_PRICE_ID=""
STRIPE_YEARLY_REPORT_PRICE_ID=""
STRIPE_MATCH_REPORT_PRICE_ID=""

# Cache / Queue
REDIS_URL="redis://localhost:6379"

# Astrology providers
# Use mock in development. In production, set a real provider and its keys.
ASTROLOGY_PROVIDER="mock"
VEDIC_RISHI_USER_ID=""
VEDIC_RISHI_API_KEY=""
DIVINE_API_KEY=""
ASTROLOGY_API_KEY=""
PROKERALA_CLIENT_ID=""
PROKERALA_CLIENT_SECRET=""
VEDASTRO_API_URL="https://api.vedastro.org/api"

# Email notifications
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Analytics
NEXT_PUBLIC_GA_ID=""

