{
    "name": "naksharix-astrology-saas",
    "version": "1.0.0",
    "private": true,
    "packageManager": "npm@10.9.2",
    "engines": {
        "node": ">=20.18.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate --schema=./prisma/schema.prisma && next build",
        "start": "next start",
        "start:standalone": "node .next/standalone/server.js",
        "start:prod": "npm run db:deploy && npm run start:standalone",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "qa:foundation": "node scripts/qa-foundation.mjs",
        "qa:engine": "node scripts/qa-engine-fixtures.mjs",
        "qa:ephemeris": "node scripts/qa-external-ephemeris.mjs",
        "qa:transit": "node scripts/qa-transit-fixtures.mjs",
        "qa:varga": "node scripts/qa-varga-fixtures.mjs",
        "qa:strength": "node scripts/qa-strength-fixtures.mjs",
        "qa:panchang": "node scripts/qa-panchang-fixtures.mjs",
        "qa:production-safety": "node scripts/qa-production-safety.mjs",
        "qa:fixture-import": "node scripts/import-verified-fixture.mjs --check-templates",
        "qa:reports-workflow": "node scripts/qa-reports-workflow.mjs",
        "qa:payments": "node scripts/qa-payments.mjs",
        "qa:pdf-generation": "node scripts/qa-pdf-generation.mjs",
        "qa:storage": "node scripts/qa-storage.mjs",
        "qa:delivery": "node scripts/qa-delivery.mjs",
        "qa:audit-security": "node scripts/qa-audit-security.mjs",
        "qa:automation": "node scripts/qa-automation.mjs",
        "qa:provider-kundli": "node scripts/qa-provider-kundli-fixtures.mjs",
        "qa:provider-panchang": "node scripts/qa-provider-panchang-fixtures.mjs",
        "qa:provider-transit": "node scripts/qa-provider-transit-fixtures.mjs",
        "qa:provider-varga": "node scripts/qa-provider-varga-fixtures.mjs",
        "qa:premium-engine": "node scripts/qa-premium-engine.mjs",
        "qa:interpretation": "node scripts/qa-interpretation.mjs",
        "qa:remedies": "node scripts/qa-remedies.mjs",
        "qa:premium-report-content": "node scripts/qa-premium-report-content.mjs",
        "qa:advanced-engine": "npm run qa:transit && npm run qa:varga && npm run qa:strength",
        "qa:all": "npm run qa:foundation && npm run qa:engine && npm run qa:provider-kundli && npm run qa:provider-panchang && npm run qa:provider-transit && npm run qa:provider-varga && npm run qa:ephemeris && npm run qa:panchang && npm run qa:transit && npm run qa:varga && npm run qa:strength && npm run qa:premium-engine && npm run qa:interpretation && npm run qa:remedies && npm run qa:premium-report-content && npm run qa:fixture-import && npm run qa:reports-workflow && npm run qa:payments && npm run qa:pdf-generation && npm run qa:storage && npm run qa:delivery && npm run qa:audit-security && npm run qa:automation && npm run qa:production-safety",
        "fixtures:generate": "node scripts/generate-provider-fixtures.mjs",
        "fixture:import": "node scripts/import-verified-fixture.mjs",
        "verify": "npm run lint && npm run typecheck && npm run build",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "@auth/prisma-adapter": "^2.10.0",
        "@hookform/resolvers": "^5.0.1",
        "@next/swc-wasm-nodejs": "^16.2.6",
        "@prisma/client": "^6.7.0",
        "@radix-ui/react-dialog": "^1.1.11",
        "@radix-ui/react-dropdown-menu": "^2.1.12",
        "@radix-ui/react-label": "^2.1.4",
        "@radix-ui/react-select": "^2.2.2",
        "@radix-ui/react-slot": "^1.2.0",
        "@radix-ui/react-tabs": "^1.1.9",
        "@react-pdf/renderer": "^4.5.1",
        "@stripe/stripe-js": "^7.0.0",
        "astronomy-engine": "^2.1.19",
        "bcryptjs": "^3.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "framer-motion": "^12.10.5",
        "ioredis": "^5.6.1",
        "jose": "^6.0.10",
        "lucide-react": "^0.503.0",
        "next": "15.5.18",
        "next-auth": "^5.0.0-beta.31",
        "nodemailer": "^8.0.7",
        "razorpay": "^2.9.6",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.56.1",
        "recharts": "^2.15.3",
        "server-only": "^0.0.1",
        "sharp": "^0.33.5",
        "stripe": "^18.1.0",
        "tailwind-merge": "^3.2.0",
        "tailwindcss-animate": "^1.0.7",
        "ws": "^8.18.2",
        "zod": "^3.24.3",
        "zustand": "^5.0.3"
    },
    "optionalDependencies": {
        "swisseph": "^0.5.17"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.15.3",
        "@types/nodemailer": "^6.4.17",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@types/ws": "^8.18.1",
        "autoprefixer": "^10.4.21",
        "eslint": "^9.25.1",
        "eslint-config-next": "^15.3.1",
        "postcss": "^8.5.14",
        "prisma": "^6.7.0",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.8.3"
    },
    "prisma": {
        "schema": "prisma/schema.prisma"
    },
    "overrides": {
        "nodemailer": "^8.0.7",
        "postcss": "^8.5.14"
    }
}
