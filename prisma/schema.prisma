generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ASTROLOGER
  CONSULTANT
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum ProfileStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ConsultantStatus {
  ONLINE
  BUSY
  OFFLINE
}

enum BookingStatus {
  PENDING
  REQUESTED
  PAYMENT_PENDING
  ACCEPTED
  CONFIRMED
  REJECTED
  COMPLETED
  CANCELED
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  VIP
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  WALLET
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  ADMIN_BYPASS
  FREE
}

enum PaymentPurpose {
  SUBSCRIPTION
  KUNDLI_REPORT
  YEARLY_REPORT
  MATCH_REPORT
  CONSULTATION
  WALLET_TOPUP
}

enum ReportPlanType {
  PREMIUM
  VIP
}

enum ReportPaymentStatus {
  PAID
  ADMIN_BYPASS
  PENDING
  FAILED
}

enum ReportRequestStatus {
  RECEIVED
  PENDING_REVIEW
  PAYMENT_PENDING
  PAID
  IN_PROGRESS
  NEEDS_INFO
  READY_FOR_GENERATION
  GENERATED
  READY_FOR_DELIVERY
  SENT
  DELIVERED
  CANCELLED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  LIVE
  COMPLETED
  CANCELED
}

enum ConsultationMode {
  CHAT
  AUDIO
  VIDEO
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  WHATSAPP
  IN_APP
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id                           String                @id @default(cuid())
  email                        String                @unique
  passwordHash                 String?
  name                         String
  image                        String?
  avatarUrl                    String?
  phone                        String?
  locale                       String                @default("en")
  role                         Role                  @default(USER)
  emailVerified                DateTime?
  emailVerifiedAt              DateTime?
  phoneVerifiedAt              DateTime?
  dob                          DateTime?
  birthTime                    String?
  birthPlace                   String?
  latitude                     Float?
  longitude                    Float?
  timezone                     String?
  googleId                     String?               @unique
  credits                      Int                   @default(25)
  walletBalance                Decimal               @default(0) @db.Decimal(12, 2)
  referralCode                 String                @unique @default(cuid())
  referredById                 String?
  referredBy                   User?                 @relation("Referrals", fields: [referredById], references: [id])
  referrals                    User[]                @relation("Referrals")
  accounts                     Account[]
  sessions                     Session[]
  otps                         OtpToken[]
  kundlis                      Kundli[]
  kundliReports                KundliReport[]
  horoscopeHistory             Horoscope[]
  numerologyReports            NumerologyReport[]
  tarotReadings                TarotReading[]
  subscriptions                Subscription[]
  payments                     Payment[]
  invoices                     Invoice[]
  purchasedReports             PurchasedReport[]
  reportRequests               ReportRequest[]
  auditLogs                    AuditLog[]             @relation("AuditActor")
  comments                     Comment[]
  blogPosts                    BlogPost[]
  notifications                Notification[]
  chatThreads                  ChatThread[]
  appointments                 Appointment[]         @relation("ClientAppointments")
  supportTickets               SupportTicket[]
  reviews                      Review[]
  affiliate                    Affiliate?
  astrologerProfile            Astrologer?
  astrologerMarketplaceProfile AstrologerProfile?
  consultantProfile            ConsultantProfile?
  clientConsultationBookings   ConsultationBooking[] @relation("ClientConsultationBookings")
  astrologerNotes              AstrologerNote[]
  payouts                      Payout[]
  adminActionLogs              AdminActionLog[]
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt

  @@index([role])
  @@index([createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  sessionToken String?   @unique
  tokenHash    String?   @unique
  ipAddress    String?
  userAgent    String?
  expires      DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model OtpToken {
  id         String    @id @default(cuid())
  userId     String?
  email      String?
  phone      String?
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
}

model Kundli {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  gender          String?
  birthDate       DateTime
  birthTime       String
  birthPlace      String
  latitude        Float
  longitude       Float
  timezone        String
  ayanamsa        String   @default("Lahiri")
  planetPositions Json
  houses          Json
  lagnaChart      Json
  navamsaChart    Json
  dashas          Json
  yogas           Json
  doshas          Json
  panchang        Json
  manglik         Json
  reportHtml      String?
  pdfUrl          String?
  isFavorite      Boolean  @default(false)
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
}

model KundliReport {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  gender      String?
  dateOfBirth DateTime
  timeOfBirth String
  birthPlace  String
  latitude    Float
  longitude   Float
  timezone    String
  language    String   @default("en")
  reportJson  Json
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Horoscope {
  id          String   @id @default(cuid())
  userId      String?
  zodiac      String
  period      String
  category    String
  locale      String   @default("en")
  content     String
  luckyNumber Int?
  luckyColor  String?
  gemstone    String?
  aiGenerated Boolean  @default(false)
  validFor    DateTime
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([zodiac, period, validFor])
  @@index([userId, createdAt])
}

model NumerologyReport {
  id                String   @id @default(cuid())
  userId            String?
  name              String
  dateOfBirth       DateTime
  lifePathNumber    Int
  destinyNumber     Int
  soulUrgeNumber    Int
  personalityNumber Int
  report            Json
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
}

model TarotReading {
  id             String   @id @default(cuid())
  userId         String?
  spread         String
  question       String?
  cards          Json
  interpretation String
  aiGenerated    Boolean  @default(true)
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  plan                   SubscriptionPlan
  status                 SubscriptionStatus
  provider               PaymentProvider
  providerCustomerId     String?
  providerSubscriptionId String?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean            @default(false)
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments               Payment[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([userId, status])
}

model Payment {
  id                String           @id @default(cuid())
  userId            String
  subscriptionId    String?
  provider          PaymentProvider
  purpose           PaymentPurpose   @default(SUBSCRIPTION)
  status            PaymentStatus
  amount            Decimal          @db.Decimal(12, 2)
  currency          String           @default("INR")
  providerOrderId   String?          @unique
  providerPaymentId String?          @unique
  couponCode        String?
  metadata          Json?
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invoice           Invoice?
  purchasedReport   PurchasedReport?
  reportRequest     ReportRequest?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([status, provider])
}

model Invoice {
  id        String   @id @default(cuid())
  userId    String
  paymentId String   @unique
  number    String   @unique
  pdfUrl    String?
  html      String?
  taxAmount Decimal  @default(0) @db.Decimal(12, 2)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PurchasedReport {
  id          String         @id @default(cuid())
  userId      String
  paymentId   String         @unique
  reportType  PaymentPurpose
  title       String
  status      String         @default("PROCESSING")
  downloadUrl String?
  metadata    Json?
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment     Payment        @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, createdAt])
}

model ReportRequest {
  id            String              @id @default(cuid())
  userId        String?
  user          User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  paymentId     String?             @unique
  payment       Payment?            @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  planType      ReportPlanType
  paymentStatus ReportPaymentStatus @default(PENDING)
  status        ReportRequestStatus @default(PENDING_REVIEW)
  reportSlug    String              @default("premium-kundli")
  deliveryEmail String
  fullName      String
  gender        String?
  dateOfBirth   String
  timeOfBirth   String
  birthPlace    String
  latitude      Float?
  longitude     Float?
  timezone      Float?
  phone         String?
  concern       String?
  language      String              @default("en")
  adminNotes    String?
  generatedPdfBytes    Bytes?
  generatedPdfFileName String?
  generatedPdfMimeType String?
  generatedPdfStorageKey String?
  generatedPdfChecksum String?
  generatedPdfStorageDriver String?
  generatedPdfSize     Int?
  generatedAt          DateTime?
  deliveryStatus       String              @default("not_ready")
  emailSentAt          DateTime?
  deliveryError        String?
  adminBypass   Boolean             @default(false)
  statusHistory ReportStatusHistory[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([planType, status])
  @@index([reportSlug])
  @@index([paymentStatus])
}

model ReportStatusHistory {
  id              String              @id @default(cuid())
  reportRequestId String
  oldStatus       ReportRequestStatus?
  newStatus       ReportRequestStatus
  actorId         String?
  actorRole       String?
  note            String?
  metadata        Json?
  reportRequest   ReportRequest       @relation(fields: [reportRequestId], references: [id], onDelete: Cascade)
  createdAt       DateTime            @default(now())

  @@index([reportRequestId, createdAt])
  @@index([actorId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  action     String
  targetType String
  targetId   String
  metadata   Json?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  percentOff     Int?
  amountOff      Decimal?  @db.Decimal(12, 2)
  currency       String?
  maxRedemptions Int?
  redeemed       Int       @default(0)
  active         Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
}

model BlogPost {
  id             String     @id @default(cuid())
  authorId       String?
  title          String
  slug           String     @unique
  excerpt        String
  content        String
  coverImage     String?
  category       String
  tags           String[]
  status         BlogStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  aiGenerated    Boolean    @default(false)
  publishedAt    DateTime?
  comments       Comment[]
  author         User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  body      String
  approved  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Astrologer {
  id              String        @id @default(cuid())
  userId          String        @unique
  bio             String
  specialties     String[]
  languages       String[]
  experienceYears Int
  rating          Float         @default(0)
  reviewCount     Int           @default(0)
  pricePerMinute  Decimal       @db.Decimal(12, 2)
  isLive          Boolean       @default(false)
  isVerified      Boolean       @default(false)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  reviews         Review[]
  streams         LiveStream[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Appointment {
  id           String            @id @default(cuid())
  userId       String
  astrologerId String
  mode         ConsultationMode
  status       AppointmentStatus @default(REQUESTED)
  scheduledAt  DateTime
  durationMins Int
  meetingUrl   String?
  notes        String?
  user         User              @relation("ClientAppointments", fields: [userId], references: [id], onDelete: Cascade)
  astrologer   Astrologer        @relation(fields: [astrologerId], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, scheduledAt])
  @@index([astrologerId, scheduledAt])
}

model ChatThread {
  id        String        @id @default(cuid())
  userId    String
  title     String
  memory    Json?
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  role      String
  content   String
  metadata  Json?
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  sentAt    DateTime?
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime            @default(now())
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  status    String   @default("OPEN")
  priority  String   @default("NORMAL")
  messages  Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id                    String               @id @default(cuid())
  userId                String
  astrologerId          String?
  astrologerProfileId   String?
  consultationBookingId String?
  rating                Int
  body                  String?
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  astrologer            Astrologer?          @relation(fields: [astrologerId], references: [id], onDelete: Cascade)
  astrologerProfile     AstrologerProfile?   @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)
  consultationBooking   ConsultationBooking? @relation(fields: [consultationBookingId], references: [id], onDelete: SetNull)
  createdAt             DateTime             @default(now())

  @@unique([userId, astrologerId])
  @@unique([consultationBookingId])
  @@index([astrologerProfileId])
}

model LiveStream {
  id           String     @id @default(cuid())
  astrologerId String
  title        String
  streamUrl    String
  startsAt     DateTime
  endsAt       DateTime?
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model AstrologerProfile {
  id                 String                @id @default(cuid())
  userId             String                @unique
  displayName        String
  photoUrl           String?
  bio                String                @default("")
  experienceYears    Int                   @default(0)
  specialization     String                @default("Vedic Astrology")
  languages          String[]              @default(["Hindi", "English"])
  consultationPrice  Decimal               @default(0) @db.Decimal(12, 2)
  pricePerSession    Decimal?              @db.Decimal(12, 2)
  city               String?
  country            String?
  introLine          String?
  availableForChat   Boolean               @default(false)
  availableForCall   Boolean               @default(false)
  availableForVideo  Boolean               @default(false)
  profileViews       Int                   @default(0)
  skills             String[]              @default([])
  certificates       Json?
  status             ProfileStatus         @default(PENDING_REVIEW)
  availabilityStatus ConsultantStatus      @default(OFFLINE)
  rating             Float                 @default(0)
  reviewCount        Int                   @default(0)
  approvedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots              AvailabilitySlot[]
  bookings           ConsultationBooking[]
  notes              AstrologerNote[]
  payouts            Payout[]
  reviews            Review[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([status, availabilityStatus])
  @@index([specialization])
}

model ConsultantProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  displayName        String
  photoUrl           String?
  bio                String           @default("")
  experienceYears    Int              @default(0)
  specialization     String           @default("Spiritual Consultant")
  languages          String[]         @default(["Hindi", "English"])
  consultationPrice  Decimal          @default(0) @db.Decimal(12, 2)
  pricePerSession    Decimal?              @db.Decimal(12, 2)
  city               String?
  country            String?
  introLine          String?
  availableForChat   Boolean               @default(false)
  availableForCall   Boolean               @default(false)
  availableForVideo  Boolean               @default(false)
  profileViews       Int                   @default(0)
  skills             String[]         @default([])
  certificates       Json?
  status             ProfileStatus    @default(PENDING_REVIEW)
  availabilityStatus ConsultantStatus @default(OFFLINE)
  rating             Float            @default(0)
  reviewCount        Int              @default(0)
  approvedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status, availabilityStatus])
}

model AvailabilitySlot {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  dayOfWeek           Int
  startTime           String
  endTime             String
  isHoliday           Boolean           @default(false)
  isActive          Boolean           @default(true)
  consultationType  String            @default("CHAT")
  status              ConsultantStatus  @default(ONLINE)
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([astrologerProfileId, dayOfWeek])
}

model ConsultationBooking {
  id                  String            @id @default(cuid())
  userId              String
  astrologerProfileId String
  mode                ConsultationMode
  status              BookingStatus     @default(REQUESTED)
  scheduledAt         DateTime
  durationMins        Int               @default(30)
  birthName           String?
  birthDate           DateTime?
  birthTime           String?
  birthPlace          String?
  question            String
  paymentStatus       PaymentStatus     @default(PENDING)
  amount              Decimal           @default(0) @db.Decimal(12, 2)
  metadata            Json?
  user                User              @relation("ClientConsultationBookings", fields: [userId], references: [id], onDelete: Cascade)
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)
  reviews             Review[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([userId, scheduledAt])
  @@index([astrologerProfileId, scheduledAt])
  @@index([status])
}

model AstrologerNote {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  userId              String?
  title               String
  body                String
  private             Boolean           @default(true)
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)
  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Payout {
  id                  String            @id @default(cuid())
  astrologerProfileId String
  userId              String
  amount              Decimal           @db.Decimal(12, 2)
  status              String            @default("PENDING")
  provider            String            @default("MANUAL")
  reference           String?
  metadata            Json?
  astrologerProfile   AstrologerProfile @relation(fields: [astrologerProfileId], references: [id], onDelete: Cascade)
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([userId, createdAt])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  metadata   Json?
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

model Affiliate {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  rate      Decimal  @default(10) @db.Decimal(5, 2)
  clicks    Int      @default(0)
  signups   Int      @default(0)
  revenue   Decimal  @default(0) @db.Decimal(12, 2)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

